# === API Configuration ===
# OpenAI-compatible API endpoint (e.g., OpenAI, Mistral, vLLM, Ollama, LiteLLM)
API_BASE_URL=https://api.example.com/v1
API_KEY=your-api-key

# === Retry settings (for 502/503/429) ===
RETRY_MAX_ATTEMPTS=8
RETRY_BASE_DELAY=2.0
RETRY_MAX_DELAY=120.0

# === Workspace ===
# For local dev:
WORKSPACE_PATH=./workspace
# For Docker: path on the HOST machine to mount
HOST_WORKSPACE_PATH=./workspace

# === File unlock command (for developer agent) ===
# Customize for your SCM (e.g., Perforce, ClearCase, or simple chmod)
FILE_UNLOCK_CMD=chmod u+w {filepath}
FILE_LOCK_CMD=chmod u-w {filepath}

# === Docker deployment ===
# Image to use (set by CI or manually)
DOCKER_IMAGE=your-registry.example.com/agent-hub:latest
# Web UI port on host
WEB_PORT=8080
# Indexer interval in seconds (3600 = 1 hour)
INDEXER_INTERVAL_SECONDS=3600

# === Host paths for bind mounts ===
# All paths are relative to docker-compose.yml location.
# The .vectordb built locally is reused directly by containers.
HOST_VECTORDB_PATH=./.vectordb
HOST_CONTEXT_PATH=./context
HOST_AGENTS_PATH=./agents
HOST_REPORTS_PATH=./reports
HOST_OUTPUT_PATH=./output
HOST_WEBLOGS_PATH=./web/logs
